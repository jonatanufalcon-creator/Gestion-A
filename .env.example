# .env.example

# Database configuration
DATABASE_URL=your_database_url

# JWT Secret
JWT_SECRET=your_jwt_secret

# API Keys
API_KEY_SERVICE_1=your_api_key_for_service_1
API_KEY_SERVICE_2=your_api_key_for_service_2

# Cloud Credentials
CLOUD_PROVIDER_ACCESS_KEY=your_access_key
CLOUD_PROVIDER_SECRET=your_secret_key
